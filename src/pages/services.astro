---
// Import necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';

// Reusing the template's existing placeholder images — swap these files
// (same filenames, in src/images/) for your own photos whenever ready.
import blueprints from '@images/blueprints-image.avif';
import personWorking from '@images/person-working.avif';
import beforeAfter from '@images/before-after.avif';
import constructionWorkers from '@images/construction-workers.avif';
import aerialView from '@images/aerial-view.avif';
import usingTools from '@images/using-tools.avif';
import { SITE } from '@data/constants';

const whatsappURL = 'https://wa.me/918639010806';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'Wedding & Pre-Wedding Photography',
    subTitle:
      'From the proposal to the final vows, we capture every glance, every tear of joy, every sacred moment. Pre-wedding sessions are intimate and unhurried, telling the story of your journey together before the big day arrives.',
    single: false,
    imgOne: blueprints,
    imgOneAlt: 'Wedding photography moment',
    imgTwo: personWorking,
    imgTwoAlt: 'Pre-wedding shoot moment',
  },
  {
    isRightSection: false,
    title: 'Videography & Cinematic Films',
    subTitle:
      'Our videography goes beyond documentation — it is storytelling. From highlight reels to full-length ceremony coverage, every film is edited with the same care and warmth we bring to every photograph.',
    img: beforeAfter,
    imgAlt: 'Wedding videography',
    btnExists: true,
    btnTitle: 'Book on WhatsApp',
    btnURL: whatsappURL,
  },
  {
    isRightSection: true,
    title: 'YouTube Live Streaming',
    subTitle:
      'Not everyone can travel for the ceremony. Our multi-camera live streaming setup lets distant family and friends join weddings and church services in real time, wherever they are.',
    single: false,
    imgOne: constructionWorkers,
    imgOneAlt: 'Live streaming setup',
    imgTwo: aerialView,
    imgTwoAlt: 'Event coverage',
  },
  {
    isRightSection: false,
    title: 'Photo Albums, Radium Printing & Creative Frames',
    subTitle:
      'The story continues after the event. We design handcrafted, archival-quality photo albums, and offer radium printing and custom creative frames that turn your favorite photographs into luminous keepsakes for the home.',
    img: usingTools,
    imgAlt: 'Photo album and frame',
    btnExists: true,
    btnTitle: 'Book on WhatsApp',
    btnURL: whatsappURL,
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  'Wedding and event photography, videography, YouTube live streaming, photo albums, and creative photo frames — from Zion Photography.';
const ogTitle = 'Our Services | Zion Photography';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': '#!',
    '@type': '#!',
    '@id': '#!',
    url: '#!',
    name: '#!',
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: '#!',
      name: '#!',
      description:
        'Zion Photography is a Christ-centric wedding and event photography & videography studio.',
    },
    inLanguage: 'en-US',
  }}
>
  {/* Intro section with a WhatsApp CTA */}
  <MainSection
    title="Every Event, Captured with Light"
    subTitle="From the first pre-wedding frame to the album in your hands, every service is built around one goal: capturing light that lasts."
    btnExists={true}
    btnTitle="Book on WhatsApp"
    btnURL={whatsappURL}
  />
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
</MainLayout>
