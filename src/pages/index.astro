---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import heroImage from '@images/hero-image.avif';
import features from '@data/features.json';
import featureImage from '@images/features-image.avif';
---

<MainLayout>
  <HeroSection
    title=`Capturing Light,<br />Creating <span
        class="text-yellow-500 dark:text-yellow-400">Memories</span>`
    subTitle="Christ-centric wedding and event photography & videography — pre-wedding shoots, live streaming, photo albums, and creative frames."
    primaryBtn="Our Services"
    primaryBtnURL="/services"
    secondaryBtn="Book on WhatsApp"
    secondaryBtnURL="/contact"
    withReview={false}
    src={heroImage}
    alt="Wedding photography by Zion Photography"
  />

  <FeaturesGeneral
    title="What We Offer"
    subTitle="Every event is a chapter. From the first pre-wedding frame to the album in your hands, we help you tell your story with light, care, and faith."
    src={featureImage}
    alt="Zion Photography services"
    features={features}
  />

  <section class="mx-auto max-w-[85rem] px-4 py-16 text-center sm:px-6 lg:px-8 lg:py-24">
    <h2 class="text-3xl font-bold text-neutral-800 sm:text-4xl dark:text-neutral-200">
      Your Story Deserves Light
    </h2>
    <p class="mx-auto mt-3 max-w-xl text-neutral-600 dark:text-neutral-400">
      Message us on WhatsApp to check dates and discuss your event.
    </p>
    <div class="mt-8 flex justify-center">
      <a
        href="https://wa.me/918639010806"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-x-3 rounded-full bg-[#25D366] px-8 py-4 text-base font-semibold text-white shadow-lg transition duration-300 hover:bg-[#1da851] hover:shadow-xl"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Book on WhatsApp
      </a>
    </div>
  </section>
</MainLayout>
